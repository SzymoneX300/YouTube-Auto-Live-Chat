{
	"manifest_version": 3,
	"name": "YouTube Auto Live Chat",
	"version": "1.0",
	"description": "Automatically switches YouTube chat to Live Chat",
	"icons": {
		"48": "icon.png",
		"128": "icon.png"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "oytybe-auto-live-chat@sx12c.xd",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"content_scripts": [
		{
			"matches": [
				"*://*.youtube.com/live_chat*",
				"*://*.youtube.com/watch*"
			],
			"all_frames": true,
			"js": ["content.js"],
			"run_at": "document_end"
		}
	]
}